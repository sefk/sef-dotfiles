[color]
    ui = auto

[alias]
    logl = log --decorate --oneline
    logla = log --decorate --oneline --all --graph
    dt = difftool
    difft = difftool
    # Default diffs use delta (unified). These opt in to difftastic's
    # syntax-aware diff for the cases it's good at (refactors, moved code);
    # avoid it on big string/data literals, where it prints the whole literal.
    dft = "!git -c diff.external=difft -c core.pager='less -R' show --ext-diff"
    dftl = "!git -c diff.external=difft -c core.pager='less -R' log -p --ext-diff"
    conflicts = !git ls-files -u | cut -f 2 | sort -u
    track = "!f() { ([ $# -eq 2 ] && ( echo \"Setting tracking for branch \" $1 \" -> \" $2;git branch --set-upstream $1 $2; ) || ( git for-each-ref --format=\"local: %(refname:short) <--sync--> remote: %(upstream:short)\" refs/heads && echo --Remotes && git remote -v)); }; f"

    ls = log --pretty=format:"%C(yellow)%h\\ %Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate
    # Lint
    lint = !git5 lint -q

    # Submit and Sync stuff
    submit = !git5 submit
    sync = "!git5 sync --sync-at=$1"
    sync-cl = !git5 status

[color]
  diff = auto
  status = auto
  branch = auto

[difftool "opendiff"]
	cmd = opendiff
	trustExitCode = true

[difftool "diffmerge"]
	cmd = diffmerge \"$LOCAL\" \"$REMOTE\"

[mergetool "opendiff"]
	cmd = "opendiff \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\""
	trustExitCode = false

[mergetool "diffmerge"]
	cmd = "diffmerge --merge --result=\"$MERGED\" \"$LOCAL\" \"$(if test -f \"$BASE\"; then echo \"$BASE\"; else echo \"$LOCAL\"; fi)\" \"$REMOTE\""
	trustExitCode = true

[mergetool "vi"]
	cmd = vi
	trustExitCode = true

[core]
	excludesfile = ~/.cvsignore
	editor = nvim
	precomposeunicode = true
	pager = delta

[github]
	user = sefk

[merge]
	tool = opendiff
	conflictstyle = zdiff3

[push]
	default = current
[diff]
	tool = diffmerge
[ghi]
	token = !security find-internet-password -a sefk -s github.com -l 'ghi token' -w
[oh-my-zsh]
	hide-status = 1
[delta]
	# unified, not side-by-side -- side-by-side doesn't fit a narrow terminal.
	# Keeps syntax highlighting, line numbers, and word-level intra-line diffs.
	side-by-side = false
	line-numbers = true
	navigate = true
[interactive]
	diffFilter = delta --color-only
