font-family = Menlo

# Mellow, grey background and pink cursor
# theme = Arthur
# theme = Treehouse
# Hacktober is kind of low contrast but satisfying
# theme = Hacktober
# theme = Synthwave
theme = Adventure

# Needed to fix ssh issues: https://ghostty.org/docs/help/terminfo
shell-integration-features = ssh-terminfo
keybind = shift+enter=text:\x1b\r
keybind = shift+page_up=unbind
keybind = shift+page_down=unbind

# Allow remote apps (e.g. tmux on studio over ssh) to set the Mac clipboard via OSC 52.
clipboard-write = allow
clipboard-read = ask

split-divider-color=yellow

# uncomment this to start every shell in tmux
# command = ~/.config/ghostty/start-tmux.sh
