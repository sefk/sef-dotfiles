#!/bin/sh
# tmux session picker via fzf

TMUX_CMD="${TMUX_CMD:-tmux}"

IN_TMUX=""
if [ -n "$TMUX" ]; then
    IN_TMUX=1
    current=$("$TMUX_CMD" display-message -p '#S')
fi

sessions=$("$TMUX_CMD" list-sessions -F '#S' 2>/dev/null)
choices=$(printf '(new session)\n%s\n(no tmux)' "$sessions")

prompt="attach tmux> "
[ -n "$IN_TMUX" ] && prompt="switch from \"$current\" to tmux> "

pick=$(echo "$choices" | fzf --height=~20 --reverse --prompt="$prompt")

case "$pick" in
    "") exit 0 ;;
    "(no tmux)") exit 0 ;;
    "(new session)")
        if [ -n "$IN_TMUX" ]; then
            "$TMUX_CMD" new-session -d && "$TMUX_CMD" switch-client -n
        else
            exec "$TMUX_CMD" new-session
        fi
        ;;
    *)
        if [ -n "$IN_TMUX" ]; then
            "$TMUX_CMD" switch-client -t "$pick"
        else
            exec "$TMUX_CMD" attach-session -t "$pick"
        fi
        ;;
esac
